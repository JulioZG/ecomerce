# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (Supabase / Railway PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# NextAuth v5
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL=http://localhost:3000

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MercadoPago (mercadopago.com.ar → Credenciales)
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# AWS SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM="DeportesStore <no-reply@tudominio.com>"
PRODUCER_EMAIL="productor@tudominio.com"

# Vercel AI SDK / OpenAI
OPENAI_API_KEY=
AI_GATEWAY_URL=   # optional: Vercel AI gateway URL
AI_IMAGE_MODEL=dall-e-3

# UploadThing (uploadthing.com)
UPLOADTHING_TOKEN=
